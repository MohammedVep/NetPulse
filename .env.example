# Frontend
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://ws.example.com/prod
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_example
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=exampleclientid
NEXT_PUBLIC_DEMO_ORG_ID=org_demo_public
NEXT_PUBLIC_DEFAULT_WORKSPACE_NAME=Recruiter Sandbox Workspace
NEXT_PUBLIC_DEFAULT_ENDPOINT_NAME=Recruiter Drill Endpoint
NEXT_PUBLIC_DEFAULT_ENDPOINT_URL=https://example.com/health
NEXT_PUBLIC_TEST_ALERT_EMAIL=recruiter-oncall@example.com
NEXT_PUBLIC_TEST_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
NEXT_PUBLIC_TEST_WEBHOOK_URL=https://webhook.site/replace-me
NEXT_PUBLIC_SHOW_TESTING_HINTS=true

# Integration drill environment
DRILL_EMAIL_ADDRESS=recruiter-oncall@example.com
DRILL_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
DRILL_WEBHOOK_RECEIVER_URL=https://webhook.site/replace-me
DRILL_WEBHOOK_SECRET_VALUE=replace-me
DRILL_SKIP_EMAIL_SUBSCRIPTION_CHECK=false

# Lambda runtime defaults (infrastructure normally injects these)
ORGANIZATIONS_TABLE=np_organizations_dev
MEMBERSHIPS_TABLE=np_memberships_dev
ENDPOINTS_TABLE=np_endpoints_dev
PROBE_RESULTS_TABLE=np_probe_results_dev
INCIDENTS_TABLE=np_incidents_dev
WS_CONNECTIONS_TABLE=np_ws_connections_dev
ALERT_CHANNELS_TABLE=np_alert_channels_dev
ALERT_DEDUPE_TABLE=np_alert_dedupe_dev

PROBE_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/np-probe-jobs-dev
INCIDENT_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/np-incident-events-dev
WS_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/np-ws-events-dev
MONTHLY_REPORTS_BUCKET=np-reports-dev-123456789012
EMAIL_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:np-alerts-email-dev
WEBSOCKET_ENDPOINT=https://xxxx.execute-api.us-east-1.amazonaws.com/prod
COGNITO_USER_POOL_ID=us-east-1_xxxxx
COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxx

# Load balancer runtime (services/load-balancer)
PORT=8080
INSTANCE_NAME=netpulse-lb
DISCOVERY_PROVIDER=consul
DISCOVERY_REFRESH_INTERVAL_MS=5000
STATIC_BACKENDS=127.0.0.1:3001,127.0.0.1:3002
CONSUL_URL=http://127.0.0.1:8500
CONSUL_SERVICE_NAME=netpulse-backend
ETCD_URL=http://127.0.0.1:2379
ETCD_KEY_PREFIX=/services/netpulse-backend/
HEALTH_PATH=/health
HEALTH_CHECK_INTERVAL_MS=5000
HEALTH_CHECK_TIMEOUT_MS=1500
LOAD_BALANCER_TIMEOUT_MS=10000
CIRCUIT_OPEN_AFTER_FAILURES=3
CIRCUIT_BASE_COOLDOWN_MS=5000
CIRCUIT_MAX_COOLDOWN_MS=60000
CIRCUIT_HALF_OPEN_SUCCESSES=2
