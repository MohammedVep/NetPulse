FROM node:22-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
ARG NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
ARG NEXT_PUBLIC_COGNITO_USER_POOL_ID=
ARG NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
ARG NEXT_PUBLIC_LOAD_BALANCER_URL=
ARG NEXT_PUBLIC_LOAD_BALANCER_HEALTH_PATH=/healthz
ARG NEXT_PUBLIC_AWS_LOAD_BALANCER_URL=
ARG NEXT_PUBLIC_GCP_LOAD_BALANCER_URL=
ARG NEXT_PUBLIC_GCP_WEB_URL=
ARG NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=
ARG NEXT_PUBLIC_PROMETHEUS_URL=
ARG NEXT_PUBLIC_PROOF_PACK_URL=/proof-pack
ARG NEXT_PUBLIC_DEMO_ORG_ID=org_demo_public
ARG NEXT_PUBLIC_DEFAULT_WORKSPACE_NAME=Recruiter Sandbox Workspace
ARG NEXT_PUBLIC_DEFAULT_ENDPOINT_NAME=Recruiter Drill Endpoint
ARG NEXT_PUBLIC_DEFAULT_ENDPOINT_URL=https://example.com/health
ARG NEXT_PUBLIC_TEST_ALERT_EMAIL=
ARG NEXT_PUBLIC_TEST_SLACK_WEBHOOK_URL=
ARG NEXT_PUBLIC_TEST_WEBHOOK_URL=
ARG NEXT_PUBLIC_SHOW_TESTING_HINTS=false

ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_COGNITO_USER_POOL_ID=$NEXT_PUBLIC_COGNITO_USER_POOL_ID
ENV NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=$NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID
ENV NEXT_PUBLIC_LOAD_BALANCER_URL=$NEXT_PUBLIC_LOAD_BALANCER_URL
ENV NEXT_PUBLIC_LOAD_BALANCER_HEALTH_PATH=$NEXT_PUBLIC_LOAD_BALANCER_HEALTH_PATH
ENV NEXT_PUBLIC_AWS_LOAD_BALANCER_URL=$NEXT_PUBLIC_AWS_LOAD_BALANCER_URL
ENV NEXT_PUBLIC_GCP_LOAD_BALANCER_URL=$NEXT_PUBLIC_GCP_LOAD_BALANCER_URL
ENV NEXT_PUBLIC_GCP_WEB_URL=$NEXT_PUBLIC_GCP_WEB_URL
ENV NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=$NEXT_PUBLIC_GRAFANA_DASHBOARD_URL
ENV NEXT_PUBLIC_PROMETHEUS_URL=$NEXT_PUBLIC_PROMETHEUS_URL
ENV NEXT_PUBLIC_PROOF_PACK_URL=$NEXT_PUBLIC_PROOF_PACK_URL
ENV NEXT_PUBLIC_DEMO_ORG_ID=$NEXT_PUBLIC_DEMO_ORG_ID
ENV NEXT_PUBLIC_DEFAULT_WORKSPACE_NAME=$NEXT_PUBLIC_DEFAULT_WORKSPACE_NAME
ENV NEXT_PUBLIC_DEFAULT_ENDPOINT_NAME=$NEXT_PUBLIC_DEFAULT_ENDPOINT_NAME
ENV NEXT_PUBLIC_DEFAULT_ENDPOINT_URL=$NEXT_PUBLIC_DEFAULT_ENDPOINT_URL
ENV NEXT_PUBLIC_TEST_ALERT_EMAIL=$NEXT_PUBLIC_TEST_ALERT_EMAIL
ENV NEXT_PUBLIC_TEST_SLACK_WEBHOOK_URL=$NEXT_PUBLIC_TEST_SLACK_WEBHOOK_URL
ENV NEXT_PUBLIC_TEST_WEBHOOK_URL=$NEXT_PUBLIC_TEST_WEBHOOK_URL
ENV NEXT_PUBLIC_SHOW_TESTING_HINTS=$NEXT_PUBLIC_SHOW_TESTING_HINTS

COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json

RUN npm ci

COPY . .

RUN npm run build --workspace @netpulse/shared
RUN npm run build --workspace @netpulse/web

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=8080
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 8080

CMD ["node", "apps/web/server.js"]
